# Optional. If set at build time, the app uses these automatically. Otherwise
# users paste them once in the app (stored in-browser). Copy to `.env.local` for dev.

# Google OAuth Client ID (for Calendar sign-in).
VITE_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# Google Maps Platform API key (for accurate geocoding -> automatic time zones).
VITE_GOOGLE_MAPS_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxx
