# Copy to `.env` (or `.env.local`) for local dev, and set the same values as
# GitHub Actions repository secrets for the deployed build.

# Supabase project URL. Defaults to the shared project if unset.
VITE_SUPABASE_URL=https://ucxfxzjgszpdhenajuxc.supabase.co

# Supabase anon (public) key — safe to ship in the client bundle.
# Find it in: Supabase dashboard → Project Settings → API → anon public.
VITE_SUPABASE_ANON_KEY=

# Optional: Google Maps Platform API key for accurate geocoding → time zones.
# Without it, a keyless OpenStreetMap fallback is used.
VITE_GOOGLE_MAPS_API_KEY=
